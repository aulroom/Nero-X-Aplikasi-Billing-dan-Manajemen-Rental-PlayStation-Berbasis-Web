{
  "name": "nero-x-backend",
  "version": "1.0.0",
  "description": "Backend API for Nero X - Aplikasi Billing dan Manajemen Rental PlayStation",
  "main": "src/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "nodemon --watch src --exec \"node -r dotenv/config src/index.js\"",
    "start": "node -r dotenv/config src/index.js",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo:all",
    "seed": "npx sequelize-cli db:seed:all",
    "lint": "echo \"No linter configured\"",
    "test": "echo \"No tests configured\""
  },
  "keywords": [
    "nero-x",
    "rental-ps",
    "express",
    "sequelize",
    "mysql"
  ],
  "author": "You",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "mysql2": "^3.22.5",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.32.1"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "sequelize-cli": "^6.6.5"
  }
}
